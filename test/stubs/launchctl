#!/bin/bash
# Test double for `launchctl`, used by `iyf-paseo-watch.sh status`.
#   launchctl list                  -> prints the label when STUB_LAUNCHCTL_LOADED set
#   launchctl print gui/<uid>/<lbl> -> prints "    pid = N" when STUB_LAUNCHCTL_PID set
case "$1" in
  list)
    [ -n "${STUB_LAUNCHCTL_LOADED:-}" ] && echo "com.iyf.paseo-watch"
    ;;
  print)
    [ -n "${STUB_LAUNCHCTL_PID:-}" ] && printf '    pid = %s\n' "$STUB_LAUNCHCTL_PID"
    ;;
  load|unload|bootstrap|bootout|enable|disable)
    # no-op success so `install`/`uninstall` can be tested without touching launchd
    ;;
esac
exit 0
